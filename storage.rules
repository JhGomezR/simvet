rules_version = '2';

// SimVet Urgencias - Firebase Storage Security Rules
// Política deny-by-default. Tres carpetas principales:
// - avatars/{uid}/...     : avatar del usuario (solo él escribe)
// - patients/{caseId}/... : fotos del paciente del caso (solo autor/admin escribe)
// - public/...            : recursos públicos de solo lectura

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function myRole() {
      return userDoc().role;
    }

    function myRoles() {
      return 'roles' in userDoc() ? userDoc().roles : [];
    }

    function hasRole(roleName) {
      return isSignedIn() && (myRole() == roleName || roleName in myRoles());
    }

    function isClinicalStaff() {
      return isSignedIn() && (
        hasRole('admin') || hasRole('veterinarian') || hasRole('assistant') || hasRole('professor')
      );
    }

    function isVetOrAdmin() {
      return isSignedIn() && (hasRole('admin') || hasRole('veterinarian'));
    }

    function myClinicId() {
      return 'clinicId' in userDoc() ? userDoc().clinicId : 'default';
    }

    function canAccessClinicPath(clinicId) {
      return isClinicalStaff() && (
        myClinicId() == clinicId
        || clinicId == 'default'
      );
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function under5MB() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    function under20MB() {
      return request.resource.size < 20 * 1024 * 1024;
    }

    // Documentos clínicos permitidos: PDF, imágenes, DOCX, TXT.
    function isClinicalDoc() {
      return request.resource.contentType.matches('application/pdf')
        || request.resource.contentType.matches('image/.*')
        || request.resource.contentType.matches('text/plain')
        || request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.wordprocessingml.document')
        || request.resource.contentType.matches('audio/.*');
    }

    // Avatares: el dueño escribe, todos los logueados leen
    match /avatars/{uid}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSelf(uid) && isImage() && under5MB();
    }

    // Imágenes de pacientes asociadas a un caso clínico
    // Por ahora abierto a lectura para usuarios logueados; la escritura se valida desde la app
    match /patients/{caseId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isImage() && under5MB();
    }

    // Documentos clínicos (historias subidas, resultados de lab, dictados de voz).
    // Lectura para logueados; escritura validando tipo y tamaño (<20MB).
    match /clinical/{clinicId}/{allPaths=**} {
      allow read: if canAccessClinicPath(clinicId);
      allow create, update: if canAccessClinicPath(clinicId) && isClinicalDoc() && under20MB();
      allow delete: if canAccessClinicPath(clinicId) && isVetOrAdmin();
    }

    // Recursos públicos (logos, placeholders del sistema)
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Deny-all por defecto
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
